# Rust build artifacts
/target/
**/target/

# Cargo registry and git checkout directories (if any)
**/.cargo/*

# Rust documentation files
**/*.html

# IDE settings
.vscode/
.idea/

# Editor swap/backup files
*.swp
*.swo
*~

# macOS artifacts
**/.DS_Store
._*
.AppleDouble
.LSOverride

# Windows
Thumbs.db
desktop.ini

# Environment files
.env
.env.local

# TLS certificates and keys
*.pem

# SQLite databases and runtime data
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# snip-sync server binary
snip-sync/snip-sync

# Per-subcrate Cargo.lock files (workspace root Cargo.lock is the source of truth)
/snip-proto/Cargo.lock
/snip-sync/Cargo.lock

# CI scaffolding (downloaded protoc binaries)
/.protoc/
/.protoc

# Coverage reports
lcov.info
coverage/
*.profraw

# Demo recording sources and video exports
/demo/*.mp4
/demo/*.tape

# snip-proto/src/snip_proto.rs is committed (standard for tonic crates)
# so that consumers don't need protoc installed.
